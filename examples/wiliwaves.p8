pico-8 cartridge // http://www.pico-8.com
version 43
__lua__

x=0 y=0 r=64 dir=false

function _draw()
		cls()
		
		// display whales
		--[[
		spr(8,10,20,1,1,false,false)
		spr(0,25,10,8,3,true,false)
		spr(0,10,50,9,3,false,true)
		spr(0,10,70,9,3,true,true)
		]]
		
		
		// hello world
		--[[
		cls()
		print("hello world")
		rectfill(80,80,120,100,12)
		circfill(70,90,20,14)
		for i=1,4 do print(i) end
		]]
		
		// moveable circle
		// cls(5)
		// circfill(x,y,7,14)

		ycent=make_waves()
		
		draw_whale(ycent)
	
end

function make_waves()
		// waves demo
		local ycent=0
		for y1=-r,r,3 do
		  for x1=-r,r,2 do
		    local dist
		    x2=x1-x
		    y2=y1-y
		    dist=sqrt(x2*x2+y2*y2)
		    z=cos(dist/40-t())*6
		    if((x1<x+2 and x1>x-2)
		    		and (y1<y+3 and y1>y-3))
		    		do
		    		ycent=r+y1-z
		    	 pset(r+x1,r+y1-z,2)
		    end
			   pset(r+x1,r+y1-z,6)
		  end
		end
		return ycent
end

function draw_whale(ycent)
		if(dir) do -- facing left
				xcent=40
		else
		  xcent=24
		end
		spr(0,x+xcent,ycent-22,8,3,
						dir,false)
end
-->8

// globals do work accross tabs
function _update()
		if (btn(0)) then
				if (x>-63) do 
		    x=x-1
		  end
		  dir = true
		end
		
		if (btn(1)) then
		  if (x<62) do
		    x=x+1
		  end
		  dir = false
		end
		
		if (btn(2)) then
				if (y>-63) do
				  y=y-1
				end
		end
		
		if (btn(3)) then
				if (y<62) do
				  y=y+1
				end
		end
end

